{
  "plugins": {
    "allow": [
      "slack",
      "file-transfer",
      "memory-core"
    ],
    "bundledDiscovery": "compat"
  },
  "meta": {
    "lastTouchedVersion": "2026.6.9",
    "lastTouchedAt": "2026-06-21T08:19:52.822Z"
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "appToken": {
        "source": "env",
        "provider": "default",
        "id": "SLACK_APP_TOKEN"
      },
      "botToken": {
        "source": "env",
        "provider": "default",
        "id": "SLACK_BOT_TOKEN"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "google/gemini-2.5-flash",
      "memorySearch": {
        "enabled": false
      },
      "compaction": {
        "reserveTokens": 2048,
        "reserveTokensFloor": 2048
      }
    }
  },
  "models": {
    "providers": {
      "google": {
        "api": "openai-completions",
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai/",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "GEMINI_API_KEY"
        },
        "models": [
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash"
          }
        ]
      },
      "groq": {
        "api": "openai-completions",
        "baseUrl": "https://api.groq.com/openai/v1",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "GROQ_API_KEY"
        },
        "models": [
          {
            "id": "llama-3.3-70b-versatile",
            "name": "Llama 3.3 70B Versatile",
            "api": "openai-completions",
            "maxTokens": 8192,
            "contextWindow": 12000,
            "contextTokens": 12000
          }
        ]
      },
      "siliconflow": {
        "api": "openai-completions",
        "baseUrl": "https://api.siliconflow.cn/v1",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "SILICONFLOW_API_KEY"
        },
        "models": [
          {
            "id": "deepseek-ai/DeepSeek-V3",
            "name": "DeepSeek V3 (SiliconFlow)",
            "api": "openai-completions",
            "maxTokens": 4096,
            "contextWindow": 64000,
            "contextTokens": 64000
          },
          {
            "id": "deepseek-ai/DeepSeek-R1",
            "name": "DeepSeek R1 (SiliconFlow)",
            "api": "openai-completions",
            "maxTokens": 4096,
            "contextWindow": 64000,
            "contextTokens": 64000
          },
          {
            "id": "Qwen/Qwen2.5-Coder-7B-Instruct",
            "name": "Qwen 2.5 Coder 7B (SiliconFlow)",
            "api": "openai-completions",
            "maxTokens": 4096,
            "contextWindow": 32000,
            "contextTokens": 32000
          },
          {
            "id": "Qwen/Qwen2.5-Coder-32B-Instruct",
            "name": "Qwen 2.5 Coder 32B (SiliconFlow)",
            "api": "openai-completions",
            "maxTokens": 4096,
            "contextWindow": 32000,
            "contextTokens": 32000
          }
        ]
      },
      "deepseek": {
        "api": "openai-completions",
        "baseUrl": "https://api.deepseek.com",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "DEEPSEEK_API_KEY"
        },
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek V3",
            "api": "openai-completions",
            "maxTokens": 8192,
            "contextWindow": 64000,
            "contextTokens": 64000
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek R1",
            "api": "openai-completions",
            "maxTokens": 8192,
            "contextWindow": 64000,
            "contextTokens": 64000
          }
        ]
      },
      "openrouter": {
        "api": "openai-completions",
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "OPENROUTER_API_KEY"
        },
        "models": [
          {
            "id": "deepseek/deepseek-chat",
            "name": "DeepSeek V3 (OpenRouter)",
            "api": "openai-completions",
            "maxTokens": 8192,
            "contextWindow": 64000,
            "contextTokens": 64000
          },
          {
            "id": "deepseek/deepseek-r1",
            "name": "DeepSeek R1 (OpenRouter)",
            "api": "openai-completions",
            "maxTokens": 8192,
            "contextWindow": 64000,
            "contextTokens": 64000
          },
          {
            "id": "qwen/qwen-2.5-coder-32b-instruct",
            "name": "Qwen 2.5 Coder 32B (OpenRouter)",
            "api": "openai-completions",
            "maxTokens": 8192,
            "contextWindow": 32000,
            "contextTokens": 32000
          }
        ]
      },
      "ollama": {
        "api": "openai-completions",
        "baseUrl": "http://127.0.0.1:11434/v1",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "OLLAMA_API_KEY"
        },
        "models": [
          {
            "id": "qwen2.5-coder:7b",
            "name": "Qwen 2.5 Coder 7B (Ollama)",
            "api": "openai-completions",
            "maxTokens": 4096,
            "contextWindow": 16000,
            "contextTokens": 16000
          },
          {
            "id": "deepseek-r1:8b",
            "name": "DeepSeek R1 8B (Ollama)",
            "api": "openai-completions",
            "maxTokens": 4096,
            "contextWindow": 16000,
            "contextTokens": 16000
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local"
  }
}
